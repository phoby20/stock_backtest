generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SearchHistory {
  id          String   @id @default(cuid())
  clerkUserId String

  ticker      String
  candle      String
  strategy    String
  rsiPeriod   Int
  oversold    Float
  overbought  Float
  macdFast    Int
  macdSlow    Int
  macdSignal  Int
  rsiLookback Int
  capital     Float

  createdAt   DateTime @default(now())

  @@index([clerkUserId])
  @@index([createdAt])
}
